# LeadingLeads.co Environment Variables
# Copy this file to ".env" and fill in your real credentials

# Server
PORT=3000
NODE_ENV=development

# Email (Nodemailer) - Gmail SMTP example
# For Gmail, generate an App Password: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=youraddress@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="LeadingLeads.co <noreply@leadingleads.co>"

# Twilio (SMS)
# Get credentials at https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# OTP settings
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# Google Sheets database
GOOGLE_SHEETS_ID=paste_your_spreadsheet_id_here
GOOGLE_SHEETS_TAB_NAME=Leads
# Paste the FULL service account JSON content (everything between { and })
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
